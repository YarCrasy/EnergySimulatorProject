<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_metric_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/simulationPointTime"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/simulationPointGeneration"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/simulationPointConsumption"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/simulationPointBalance"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/simulationPointClouds"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/simulationPointIrradiance"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />
</LinearLayout>
